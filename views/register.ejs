<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <link rel="icon" href="/icons/file-uploader.png" type="image/png">
    <script src="/js/validation.js" defer></script>
    <link rel="stylesheet" href="/css/auth.css">
    <title>Register - File Uploader</title>
</head>
<body>
    <header>
        <%- include("partials/header") %>
    </header>

    <main>
        <section class="auth-container">

            <form action="/register" method="POST" class="auth-form">

                <h1>Register on File Uploader</h1>

                <% if (errors && errors.length > 0) { %>
                    <div class="error-container">
                        <ul class="error-list">
                            <% errors.forEach(error => { %>
                                <li><%= error.msg %></li>
                            <% }) %>
                        </ul>
                    </div>
                <% } %>

                <div class="name-row">

                    <div class="input-group">
                        <label for="firstName">First Name</label>
                        <input type="text" id="firstName" name="firstName" minlength="3" maxlength="15"
                            value="<%= data.firstName || '' %>" required>
                        <small>3–15 characters</small>
                    </div>

                    <div class="input-group">
                        <label for="lastName">Last Name</label>
                        <input type="text" id="lastName" name="lastName" minlength="3" maxlength="15"
                            value="<%= data.lastName || '' %>" required>
                        <small>3–15 characters</small>
                    </div>

                </div>

                <div class="input-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email"
                        value="<%= data.email || '' %>" required>
                    <small>Enter your email address</small>
                </div>

                <div class="input-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password"
                        minlength="6" maxlength="20" required>
                    <small>6–20 characters</small>
                </div>

                <div class="input-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword"
                        minlength="6" maxlength="20" required>
                    <small>Must match password</small>
                </div>

                <button type="submit" class="btn primary">
                    Create Account
                </button>

                <p class="auth-switch">
                    Already have an account?
                    <a href="/login">Login</a>
                </p>

            </form>

        </section>
    </main>

    <footer>
        <%- include("partials/footer") %>
    </footer>

</body>
</html>