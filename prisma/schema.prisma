datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  first_name    String
  last_name     String
  password_hash String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model Session {
  id         String   @id
  sid        String   @unique
  data       String?
  expiresAt  DateTime
}